{
  "name": "@achamaro/tailwindcss-iconify-icon",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.7.0",
  "description": "Tailwind CSS plugin for Iconify Icon",
  "keywords": [
    "tailwindcss",
    "iconify",
    "icon"
  ],
  "type": "module",
  "author": "achamaro",
  "license": "MIT",
  "homepage": "https://github.com/achamaro/tailwindcss-plugins/tree/main/packages/iconify-icon#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/achamaro/tailwindcss-plugins.git",
    "directory": "packages/iconify-icon"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "svgo": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.2.5",
    "eslint-config-custom": "workspace:*",
    "iconify-icon": "^3.0.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsconfig": "workspace:*",
    "tsup": "^8.5.1",
    "utility": "workspace:^",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "tailwindcss": "*"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  }
}
